{
  "name": "jvm-debug-mcp",
  "version": "1.0.0",
  "description": "MCP server for debugging Java/Kotlin applications via JDWP",
  "main": "dist/index.js",
  "bin": {
    "jvm-debug-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && eslint . && prettier --check . && vitest run"
  },
  "keywords": [
    "mcp",
    "java",
    "kotlin",
    "debug",
    "jdwp",
    "debugger",
    "breakpoint",
    "spring-boot",
    "gradle",
    "maven",
    "model-context-protocol"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Riku-KANO/jvm-debug-mcp.git"
  },
  "homepage": "https://riku-kano.github.io/jvm-debug-mcp/",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
